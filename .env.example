# Email Agent Configuration
# Copy this file to .env and fill in your values

# Gmail Configuration
GMAIL_EMAIL=your.gmail.address@gmail.com
GMAIL_PASSWORD=your-gmail-app-password

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Optional: ngrok webhook URL (for remote Telegram access)
# TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# Local LLM Configuration
LLM_ENDPOINT=http://localhost:8131
LLM_MODEL=unsloth/Qwen3.5-35B-A3B-GGUF:Q4_K_M
LLM_TIMEOUT_SECONDS=60

# Scheduler Configuration
FETCH_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
SKIP_PROMOTIONS=true
PEEK_MODE=true

# Notion Integration (future use)
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# ngrok Authentication Token (for docker-compose deployment)
# NGROK_AUTHTOKEN=your-ngrok-authtoken
